---
const links = [
  {
    label: 'Servicios',
    items: [
      { href: '/servicios#corte',    label: 'Corte de Autor',   title: 'Corte de cabello profesional Barranquilla' },
      { href: '/servicios#barba',    label: 'Diseño de Barba',  title: 'Diseño de barba Barranquilla' },
      { href: '/servicios#facial',   label: 'Ritual Facial',    title: 'Tratamiento facial masculino Barranquilla' },
    ],
  },
  {
    label: 'Empresa',
    items: [
      { href: '/nosotros', label: 'Nosotros',  title: 'Conoce a Jaime Corcho' },
      { href: '/casos',    label: 'Casos',     title: 'Resultados y testimonios' },
      { href: '/faq',      label: 'FAQ',       title: 'Preguntas frecuentes barbería' },
    ],
  },
]

const socials = [
  { href: 'https://wa.me/573001234567', label: 'WhatsApp', title: 'WhatsApp Jaime Corcho Barbería', icon: 'whatsapp' },
  { href: 'https://instagram.com/jaimecorcho', label: 'Instagram', title: 'Instagram Jaime Corcho Barbería', icon: 'instagram' },
  { href: 'https://facebook.com/jaimecorcho', label: 'Facebook', title: 'Facebook Jaime Corcho Barbería', icon: 'facebook' },
]
---

<footer class="footer">
  <div class="divider"></div>

  <div class="container footer__inner">

    <!-- Brand -->
    <div class="footer__brand">
      <a href="/" title="Jaime Corcho Barbería Premium Barranquilla" class="footer__logo">
        JAIME<span> CORCHO</span>
      </a>
      <p class="footer__brand-desc">
        Barbería premium en Barranquilla. Precisión técnica,
        asesoría personalizada y experiencia de alto nivel
        para el hombre que cuida su imagen.
      </p>
      <!-- Socials -->
      <div class="footer__socials">
        {socials.map(s => (
          <a href={s.href} title={s.title} class="footer__social" target="_blank" rel="noopener" aria-label={s.label}>
            {s.icon === 'whatsapp' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            )}
            {s.icon === 'instagram' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            )}
            {s.icon === 'facebook' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            )}
          </a>
        ))}
      </div>
    </div>

    <!-- Nav columns -->
    {links.map(col => (
      <div class="footer__col">
        <h4 class="footer__col-title">{col.label}</h4>
        <ul>
          {col.items.map(item => (
            <li>
              <a href={item.href} title={item.title} class="footer__link">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}

    <!-- Contact -->
    <div class="footer__col">
      <h4 class="footer__col-title">Contacto</h4>
      <address class="footer__address">
        <p>Alto Prado, Barranquilla<br />Atlántico, Colombia</p>
        <a href="tel:+573001234567" title="Llamar a Jaime Corcho Barbería">+57 300 123 4567</a>
        <a href="mailto:info@jaimecorcho.com" title="Email Jaime Corcho Barbería">info@jaimecorcho.com</a>
      </address>
    </div>

  </div>

  <!-- Bottom bar -->
  <div class="container footer__bottom">
    <p>&copy; {new Date().getFullYear()} Jaime Corcho Barbería Premium. Todos los derechos reservados.</p>
    <p>
      <a href="/politica-privacidad" title="Política de privacidad">Privacidad</a>
      &nbsp;&bull;&nbsp;
      <a href="/terminos" title="Términos y condiciones">Términos</a>
    </p>
  </div>
</footer>

<style>
.footer { padding-top: 1px; background: var(--color-surface); }
.footer__inner {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 3rem;
  padding-top: 4rem;
  padding-bottom: 4rem;
}
.footer__logo {
  font-family: var(--font-serif);
  font-size: 1.4rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--color-white);
}
.footer__logo span { color: var(--color-gold); }
.footer__brand-desc {
  margin-top: 1rem;
  font-size: 0.875rem;
  line-height: 1.7;
  max-width: 28ch;
}
.footer__socials {
  display: flex;
  gap: 0.75rem;
  margin-top: 1.5rem;
}
.footer__social {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2.25rem;
  height: 2.25rem;
  border: 1px solid var(--color-border);
  color: var(--color-gray);
  transition: border-color 0.25s, color 0.25s;
}
.footer__social:hover { border-color: var(--color-gold); color: var(--color-gold); }

.footer__col-title {
  font-family: var(--font-sans);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-gold);
  margin-bottom: 1.25rem;
}
.footer__col ul { display: flex; flex-direction: column; gap: 0.75rem; }
.footer__link {
  font-size: 0.875rem;
  color: var(--color-gray);
  transition: color 0.2s;
}
.footer__link:hover { color: var(--color-white); }
.footer__address {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  font-style: normal;
  font-size: 0.875rem;
  color: var(--color-gray);
}
.footer__address a { color: var(--color-gray); transition: color 0.2s; }
.footer__address a:hover { color: var(--color-gold); }

.footer__bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 1.5rem;
  padding-bottom: 1.5rem;
  border-top: 1px solid var(--color-border);
  font-size: 0.8rem;
  color: var(--color-gray);
}
.footer__bottom a { color: var(--color-gray); transition: color 0.2s; }
.footer__bottom a:hover { color: var(--color-gold); }

@media (max-width: 900px) {
  .footer__inner { grid-template-columns: 1fr 1fr; }
  .footer__brand { grid-column: 1 / -1; }
}
@media (max-width: 600px) {
  .footer__inner { grid-template-columns: 1fr; }
  .footer__bottom { flex-direction: column; gap: 0.75rem; text-align: center; }
}
</style>
