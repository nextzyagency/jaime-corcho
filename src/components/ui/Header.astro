---
const navLinks = [
  { href: '/',          label: 'Inicio',    title: 'Inicio - Jaime Corcho Barbería' },
  { href: '/servicios', label: 'Servicios', title: 'Servicios de barbería premium en Barranquilla' },
  { href: '/nosotros',  label: 'Nosotros',  title: 'Conoce la historia de Jaime Corcho' },
  { href: '/casos',     label: 'Casos',     title: 'Resultados y testimonios de clientes' },
  { href: '/faq',       label: 'Contacto',  title: 'Contacto y preguntas frecuentes' },
]

const current = Astro.url.pathname
---

<header id="site-header" class="header">
  <div class="container header__inner">

    <!-- Logo -->
    <a href="/" title="Jaime Corcho Barbería Premium Barranquilla" class="header__logo">
      <span class="header__logo-text">JAIME<span class="header__logo-gold"> CORCHO</span></span>
      <span class="header__logo-tagline">Barbería Premium · Barranquilla</span>
    </a>

    <!-- Desktop nav -->
    <nav class="header__nav" aria-label="Navegación principal">
      <ul class="header__nav-list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              title={link.title}
              class={`header__nav-link ${current === link.href ? 'header__nav-link--active' : ''}`}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- CTA Desktop -->
    <a
      href="https://wa.me/573001234567?text=Hola%2C%20quiero%20agendar%20una%20cita"
      title="Agendar cita en Jaime Corcho Barbería"
      class="btn-primary header__cta"
      target="_blank"
      rel="noopener"
    >
      Agendar Cita
    </a>

    <!-- Hamburger -->
    <button
      id="menu-toggle"
      class="header__hamburger"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span></span><span></span><span></span>
    </button>

  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="header__mobile" aria-hidden="true">
    <nav aria-label="Menú móvil">
      <ul>
        {navLinks.map(link => (
          <li>
            <a href={link.href} title={link.title} class="header__mobile-link">
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  transition: background 0.4s ease, box-shadow 0.4s ease;
}
.header.scrolled {
  background: rgba(10, 10, 10, 0.95);
  backdrop-filter: blur(12px);
  box-shadow: 0 1px 0 var(--color-border);
}

.header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  height: 5rem;
}

.header__logo { display: flex; flex-direction: column; gap: 0.1rem; }
.header__logo-text {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--color-white);
  line-height: 1;
}
.header__logo-gold { color: var(--color-gold); }
.header__logo-tagline {
  font-size: 0.6rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-gray);
  margin-top: 0.2rem;
}

.header__nav-list {
  display: flex;
  gap: 2.5rem;
  align-items: center;
}
.header__nav-link {
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-gray);
  transition: color 0.25s ease;
  position: relative;
}
.header__nav-link::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--color-gold);
  transition: width 0.3s var(--ease-smooth);
}
.header__nav-link:hover,
.header__nav-link--active { color: var(--color-white); }
.header__nav-link:hover::after,
.header__nav-link--active::after { width: 100%; }

.header__cta { font-size: 0.75rem; padding: 0.7rem 1.5rem; }

/* Hamburger */
.header__hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 0.5rem;
}
.header__hamburger span {
  display: block;
  width: 24px;
  height: 1.5px;
  background: var(--color-white);
  transition: transform 0.3s ease, opacity 0.3s ease;
}

/* Mobile menu */
.header__mobile {
  display: none;
  position: absolute;
  top: 5rem;
  left: 0;
  right: 0;
  background: rgba(10, 10, 10, 0.98);
  backdrop-filter: blur(12px);
  border-top: 1px solid var(--color-border);
  padding: 2rem var(--section-px);
  transform: translateY(-10px);
  opacity: 0;
  pointer-events: none;
  transition: transform 0.35s var(--ease-out), opacity 0.35s var(--ease-out);
}
.header__mobile.open {
  transform: translateY(0);
  opacity: 1;
  pointer-events: all;
}
.header__mobile ul { display: flex; flex-direction: column; gap: 1.5rem; }
.header__mobile-link {
  font-size: 1.5rem;
  font-family: var(--font-serif);
  color: var(--color-white);
  transition: color 0.2s;
}
.header__mobile-link:hover { color: var(--color-gold); }

@media (max-width: 900px) {
  .header__nav, .header__cta { display: none; }
  .header__hamburger { display: flex; }
  .header__mobile { display: block; }
}
</style>

<script>
const header     = document.getElementById('site-header')!
const toggle     = document.getElementById('menu-toggle')!
const mobileMenu = document.getElementById('mobile-menu')!
let   isOpen     = false

// Scroll effect
window.addEventListener('scroll', () => {
  header.classList.toggle('scrolled', window.scrollY > 40)
}, { passive: true })

// Toggle mobile
toggle.addEventListener('click', () => {
  isOpen = !isOpen
  mobileMenu.classList.toggle('open', isOpen)
  toggle.setAttribute('aria-expanded', String(isOpen))
})

// Close on link click
mobileMenu.querySelectorAll('a').forEach(a =>
  a.addEventListener('click', () => {
    isOpen = false
    mobileMenu.classList.remove('open')
    toggle.setAttribute('aria-expanded', 'false')
  })
)
</script>
