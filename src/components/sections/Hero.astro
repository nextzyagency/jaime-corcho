---
import { Image } from 'astro:assets'
import heroImg from '../../assets/hero-barber.png'
---
<section class="hero" aria-label="Barbería Premium en Barranquilla">

  <!-- Background image/overlay -->
  <div class="hero__bg" aria-hidden="true">
    <Image
      src={heroImg}
      alt="Barbería premium Jaime Corcho en Barranquilla"
      class="hero__bg-img"
      loading="eager"
      fetchpriority="high"
    />
    <div class="hero__bg-gradient"></div>
    <div class="hero__bg-noise"></div>
  </div>

  <!-- Floating accent lines -->
  <div class="hero__lines" aria-hidden="true">
    <span class="hero__line hero__line--1"></span>
    <span class="hero__line hero__line--2"></span>
  </div>

  <div class="container hero__content">

    <!-- Eyebrow -->
    <p class="eyebrow gsap-fade" id="hero-eyebrow">Barranquilla · Colombia</p>

    <!-- H1 — Primary keyword -->
    <h1 class="hero__h1 gsap-up" id="hero-h1">
      Barbería Premium<br />
      <em>en Barranquilla</em>
    </h1>

    <!-- Subtitle -->
    <p class="hero__sub gsap-up" id="hero-sub">
      Precisión técnica y asesoría personalizada para potenciar
      tu imagen. Cada corte es un análisis de tu morfología facial.
    </p>

    <!-- CTA row -->
    <div class="hero__actions gsap-up" id="hero-actions">
      <a
        href="https://wa.me/573001234567?text=Hola%2C%20quiero%20agendar%20una%20cita"
        title="Agendar cita en Jaime Corcho Barbería Premium"
        class="btn-primary"
        target="_blank"
        rel="noopener"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Agendar Cita Ahora
      </a>
      <a href="/servicios" title="Ver servicios de barbería premium Barranquilla" class="btn-outline">
        Ver Servicios
      </a>
    </div>

    <!-- Stats -->
    <div class="hero__stats gsap-up" id="hero-stats">
      <div class="hero__stat">
        <span class="hero__stat-num">+500</span>
        <span class="hero__stat-label">Clientes atendidos</span>
      </div>
      <div class="hero__stat-divider" aria-hidden="true"></div>
      <div class="hero__stat">
        <span class="hero__stat-num">4.9★</span>
        <span class="hero__stat-label">Valoración media</span>
      </div>
      <div class="hero__stat-divider" aria-hidden="true"></div>
      <div class="hero__stat">
        <span class="hero__stat-num">100%</span>
        <span class="hero__stat-label">Personalizado</span>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll" aria-hidden="true">
    <span class="hero__scroll-line"></span>
    <span class="hero__scroll-text">Scroll</span>
  </div>
</section>

<style>
.hero {
  position: relative;
  min-height: 100svh;
  display: flex;
  align-items: center;
  overflow: hidden;
  background: var(--color-bg);
}

.hero__bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero__bg-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.35;
  filter: grayscale(0.4) contrast(1.1);
}
.hero__bg-gradient {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(to bottom, rgba(10,10,10,0.4) 0%, var(--color-bg) 90%),
    radial-gradient(ellipse 60% 60% at 70% 40%, rgba(194,168,120,0.08) 0%, transparent 70%);
}
.hero__bg-noise {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
  opacity: 0.4;
}

.hero__lines { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
.hero__line {
  position: absolute;
  background: linear-gradient(to bottom, transparent, var(--color-gold), transparent);
  width: 1px;
  height: 60%;
  opacity: 0.15;
}
.hero__line--1 { left: 30%; top: 20%; }
.hero__line--2 { right: 20%; top: 10%; opacity: 0.08; }

.hero__content {
  position: relative;
  z-index: 1;
  padding-top: 12rem;
  padding-bottom: 8rem;
  max-width: 850px;
}

.hero__h1 {
  font-size: clamp(3rem, 8vw, 5.5rem);
  color: var(--color-white);
  margin-bottom: 2rem;
  line-height: 1.05;
}
.hero__h1 em {
  font-style: italic;
  color: var(--color-gold);
}

.hero__sub {
  font-size: clamp(1.1rem, 1.8vw, 1.35rem);
  max-width: 50ch;
  margin-bottom: 3.5rem;
  color: var(--color-gray-light);
}

.hero__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-bottom: 4rem;
}

.hero__stats {
  display: flex;
  align-items: center;
  gap: 2.5rem;
  flex-wrap: wrap;
}
.hero__stat { display: flex; flex-direction: column; gap: 0.25rem; }
.hero__stat-num {
  font-family: var(--font-serif);
  font-size: 2rem;
  font-weight: 700;
  color: var(--color-gold);
  line-height: 1;
}
.hero__stat-label {
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  color: var(--color-gray);
  text-transform: uppercase;
}
.hero__stat-divider {
  width: 1px;
  height: 2.5rem;
  background: var(--color-border);
}

.hero__scroll {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  z-index: 1;
}
.hero__scroll-line {
  display: block;
  width: 1px;
  height: 3rem;
  background: linear-gradient(to bottom, var(--color-gold), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}
.hero__scroll-text {
  font-size: 0.65rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-gray);
}

@keyframes scrollPulse {
  0%, 100% { opacity: 0.3; transform: scaleY(1); }
  50%       { opacity: 1;   transform: scaleY(1.1); }
}

@media (max-width: 600px) {
  .hero__stats { gap: 1.5rem; }
  .hero__stat-divider { display: none; }
}
</style>

<script>
import { gsap } from 'gsap'

const tl = gsap.timeline({ defaults: { ease: 'power3.out', duration: 1 } })

tl.to('#hero-eyebrow', { opacity: 1, duration: 0.6 }, 0.2)
  .to('#hero-h1',      { opacity: 1, y: 0 }, 0.4)
  .to('#hero-sub',     { opacity: 1, y: 0 }, 0.6)
  .to('#hero-actions', { opacity: 1, y: 0 }, 0.75)
  .to('#hero-stats',   { opacity: 1, y: 0 }, 0.9)
</script>
