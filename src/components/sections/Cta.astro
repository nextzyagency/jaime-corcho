---
<section class="cta-section section" aria-labelledby="cta-heading">
  <div class="cta-section__bg" aria-hidden="true">
    <div class="cta-section__grain"></div>
    <div class="cta-section__accent"></div>
  </div>

  <div class="container cta-section__inner">

    <div class="cta-section__content">
      <span class="eyebrow">Reserva tu lugar</span>
      <h2 id="cta-heading" class="gsap-up">
        Tu imagen es tu<br />
        <em>primera impresión</em>
      </h2>
      <span class="gold-line gsap-fade"></span>
      <p class="cta-section__body gsap-up">
        Los cupos son limitados. Agenda tu cita ahora y recibe una
        asesoría de imagen personalizada sin costo adicional.
      </p>

      <!-- Urgency badge -->
      <div class="cta-section__urgency gsap-up">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Próxima disponibilidad: esta semana</span>
      </div>

      <!-- Actions -->
      <div class="cta-section__actions gsap-up">
        <a
          href="https://wa.me/573001234567?text=Hola%2C%20quiero%20agendar%20mi%20cita"
          title="Agendar cita barbería premium Barranquilla — Jaime Corcho"
          class="btn-primary cta-section__btn"
          target="_blank"
          rel="noopener"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Agendar por WhatsApp
        </a>
        <a
          href="tel:+573001234567"
          title="Llamar a Jaime Corcho Barbería"
          class="btn-outline"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.63A2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14h0v2.92z"/></svg>
          Llamar directamente
        </a>
      </div>
    </div>

    <!-- Contact info aside -->
    <aside class="cta-section__info">
      <div class="cta-section__info-item">
        <div class="cta-section__info-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div>
          <strong>Ubicación</strong>
          <p>Alto Prado, Barranquilla<br />Atlántico, Colombia</p>
        </div>
      </div>
      <div class="cta-section__info-item">
        <div class="cta-section__info-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div>
          <strong>Horario</strong>
          <p>Lun – Sáb: 9:00 AM – 8:00 PM<br />Dom: Cerrado</p>
        </div>
      </div>
      <div class="cta-section__info-item">
        <div class="cta-section__info-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.63A2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14h0v2.92z"/></svg>
        </div>
        <div>
          <strong>WhatsApp / Teléfono</strong>
          <p><a href="tel:+573001234567" title="Llamar a Jaime Corcho">+57 300 123 4567</a></p>
        </div>
      </div>
      <div class="cta-section__info-item">
        <div class="cta-section__info-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div>
          <strong>Email</strong>
          <p><a href="mailto:info@jaimecorcho.com" title="Email Jaime Corcho Barbería">info@jaimecorcho.com</a></p>
        </div>
      </div>
    </aside>

  </div>
</section>

<style>
.cta-section {
  position: relative;
  background: var(--color-surface);
  overflow: hidden;
}
.cta-section__bg { position: absolute; inset: 0; pointer-events: none; }
.cta-section__accent {
  position: absolute;
  top: -50%;
  right: -10%;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(194,168,120,0.06) 0%, transparent 70%);
}
.cta-section__grain {
  position: absolute;
  inset: 0;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
}

.cta-section__inner {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 5rem;
  align-items: start;
}

.cta-section__body {
  max-width: 52ch;
  font-size: 1.05rem;
  margin-bottom: 1.5rem;
}

.cta-section__urgency {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  color: var(--color-gold);
  border: 1px solid rgba(194,168,120,0.3);
  padding: 0.5rem 1rem;
  margin-bottom: 2rem;
  letter-spacing: 0.05em;
}

.cta-section__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
}
.cta-section__btn { font-size: 0.875rem; }

/* Info aside */
.cta-section__info {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  padding: 2.5rem;
  border: 1px solid var(--color-border);
  background: var(--color-card);
}
.cta-section__info-item {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}
.cta-section__info-icon {
  width: 2.5rem;
  height: 2.5rem;
  border: 1px solid var(--color-border);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-gold);
  flex-shrink: 0;
}
.cta-section__info-item strong {
  display: block;
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-gold);
  margin-bottom: 0.35rem;
}
.cta-section__info-item p,
.cta-section__info-item a {
  font-size: 0.875rem;
  color: var(--color-gray);
  line-height: 1.6;
}
.cta-section__info-item a:hover { color: var(--color-white); }

@media (max-width: 900px) {
  .cta-section__inner { grid-template-columns: 1fr; gap: 3rem; }
}
</style>

<script>
import { gsap } from 'gsap'
import { ScrollTrigger } from 'gsap/ScrollTrigger'

gsap.registerPlugin(ScrollTrigger)

gsap.from('.cta-section__content', {
  x: -40,
  opacity: 0,
  duration: 0.9,
  ease: 'power3.out',
  scrollTrigger: { trigger: '.cta-section', start: 'top 80%' },
})
gsap.from('.cta-section__info', {
  x: 40,
  opacity: 0,
  duration: 0.9,
  ease: 'power3.out',
  scrollTrigger: { trigger: '.cta-section', start: 'top 80%' },
})
</script>
