---
import '../styles/global.css'

interface Props {
  title: string
  description: string
  canonical?: string
  ogImage?: string
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/og-image.jpg',
} = Astro.props
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />

    <!-- SEO Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:locale"      content="es_CO" />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Schema.org LocalBusiness -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "HairSalon",
      "name": "Jaime Corcho Barbería",
      "description": "Barbería premium en Barranquilla especializada en cortes de autor, diseño de barba y rituales faciales masculinos.",
      "url": "https://jaimecorcho.com",
      "telephone": "+573001234567",
      "email": "info@jaimecorcho.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Alto Prado",
        "addressLocality": "Barranquilla",
        "addressRegion": "Atlántico",
        "addressCountry": "CO"
      },
      "priceRange": "$$$",
      "openingHours": "Mo-Sa 09:00-20:00",
      "sameAs": [
        "https://instagram.com/jaimecorcho",
        "https://facebook.com/jaimecorcho"
      ]
    }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
